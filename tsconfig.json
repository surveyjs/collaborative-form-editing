{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "types": [
            "node"
        ],
        "noEmit": true
    },
    "include": [
        "packages/frontend/**/*",
        "packages/server-nodejs/**/*",
        "e2e/**/*.ts",
        "playwright.config.ts",
        "vite.config.ts"
    ]
}
